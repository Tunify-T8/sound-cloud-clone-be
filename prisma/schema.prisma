generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(uuid())
  username                String                   @unique
  email                   String                   @unique
  bio                     String?
  location                String?
  visibility              Visibility               @default(PUBLIC)
  suspensionReason        String?
  role                    UserType
  gender                  Gender
  avatarUrl               String?
  bannedById              String?
  coverUrl                String?
  createdAt               DateTime                 @default(now())
  dateOfBirth             DateTime
  deletedAt               DateTime?
  displayName             String?
  isActive                Boolean                  @default(true)
  isBanned                Boolean                  @default(false)
  isDeleted               Boolean                  @default(false)
  isSuspended             Boolean                  @default(false)
  isVerified              Boolean                  @default(false)
  lastLoginAt             DateTime?
  loginMethod             LoginMethod
  passHash                String?
  suspendedById           String?
  suspendedUntil          DateTime?
  updatedAt               DateTime                 @updatedAt
  isCertified             Boolean                  @default(false)
  collections             Collection[]
  collectionLikes         CollectionLike[]
  commentsDeleted         Comment[]                @relation("CommentDeletedBy")
  commentsHidden          Comment[]                @relation("CommentHiddenBy")
  comments                Comment[]
  conversations1          Conversation[]           @relation("ConversationUser1")
  conversations2          Conversation[]           @relation("ConversationUser2")
  emailVerificationTokens EmailVerificationToken[]
  following               Follow[]                 @relation("Follower")
  followers               Follow[]                 @relation("Following")
  sentMessages            Message[]
  notificationsTriggered  Notification[]           @relation("NotificationActor")
  notificationsReceived   Notification[]           @relation("NotificationRecipient")
  notificationPreferences NotificationPreference[]
  oauthAccounts           OAuthAccount[]
  passwordResetTokens     PasswordResetToken[]
  payments                Payment[]
  playHistory             PlayHistory[]
  refreshTokens           RefreshToken[]
  submittedReports        Report[]                 @relation("Reporter")
  reviewedReports         Report[]                 @relation("ReviewedBy")
  reposts                 Repost[]
  subscriptions           Subscription[]
  tracksDeleted           Track[]                  @relation("TrackDeletedBy")
  tracksHidden            Track[]                  @relation("TrackHiddenBy")
  tracks                  Track[]                  @relation("TrackOwner")
  trackLikes              TrackLike[]
  bannedBy                User?                    @relation("UserBans", fields: [bannedById], references: [id])
  bannedUsers             User[]                   @relation("UserBans")
  suspendedBy             User?                    @relation("UserSuspensions", fields: [suspendedById], references: [id])
  suspendedUsers          User[]                   @relation("UserSuspensions")
  blockedBy               UserBlock[]              @relation("Blocked")
  blocking                UserBlock[]              @relation("Blocker")
  socialLinks             UserSocialLink[]
  UserTrackProgress       UserTrackProgress[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  isActive  Boolean   @default(true)
  revokedAt DateTime?
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  expiresAt DateTime
  revokedAt DateTime?
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model OAuthAccount {
  id             String        @id @default(uuid())
  provider       OAuthProvider
  accessToken    String        @unique
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  expiresAt      DateTime?
  providerUserId String
  refreshToken   String?
  updatedAt      DateTime      @updatedAt
  userId         String
  user           User          @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
}

model UserSocialLink {
  id        String         @id @default(uuid())
  platform  SocialPlatform
  url       String
  createdAt DateTime       @default(now())
  deletedAt DateTime?
  updatedAt DateTime       @updatedAt
  userId    String
  user      User           @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
  @@index([userId])
}

model Genre {
  id        String     @id @default(uuid())
  label     String     @unique
  tracks    Track[]
  subgenres subGenre[]

  @@index([label])
}

model subGenre {
  id      String  @id @default(uuid())
  name    String
  genreId String
  tracks  Track[]
  genre   Genre   @relation(fields: [genreId], references: [id])

  @@unique([genreId, name])
  @@index([genreId])
}

model Track {
  id                 String                   @id @default(uuid())
  userId             String
  genreId            String?
  title              String
  description        String?
  releaseDate        DateTime?
  audioUrl           String
  durationSeconds    Int
  waveformUrl        String?
  fileFormat         FileFormat
  fileSizeBytes      Int?
  transcodingStatus  TranscodingStatus        @default(processing)
  coverUrl           String?
  isPublic           Boolean                  @default(true)
  privateToken       String?
  requiresPremium    Boolean                  @default(false)
  previewEnabled     Boolean                  @default(false)
  previewStart       Int?
  previewDuration    Int?
  contentWarning     Boolean                  @default(false)
  isHidden           Boolean                  @default(false)
  hiddenAt           DateTime?
  hiddenBy           String?
  isDeleted          Boolean                  @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  subGenreId         String?
  allowComments      Boolean                  @default(true)
  allowDownloads     Boolean                  @default(false)
  allowOffline       Boolean                  @default(false)
  bitrateKbps        Int                      @default(320)
  displayEmbedCode   Boolean                  @default(true)
  enableAppPlayback  Boolean                  @default(true)
  includeInRSS       Boolean                  @default(true)
  isrc               String?
  pLine              String?
  publisher          String?
  recordLabel        String?
  sampleRateHz       Int                      @default(44100)
  showCommentsPublic Boolean                  @default(true)
  showInsightsPublic Boolean                  @default(false)
  collectionTracks   CollectionTrack[]
  comments           Comment[]
  playHistory        PlayHistory[]
  reposts            Repost[]
  deletedByUser      User?                    @relation("TrackDeletedBy", fields: [deletedBy], references: [id])
  genre              Genre?                   @relation(fields: [genreId], references: [id])
  hiddenByUser       User?                    @relation("TrackHiddenBy", fields: [hiddenBy], references: [id])
  subgenre           subGenre?                @relation(fields: [subGenreId], references: [id])
  user               User                     @relation("TrackOwner", fields: [userId], references: [id])
  trackArtists       TrackArtist[]
  likes              TrackLike[]
  regionRestrictions TrackRegionRestriction[]
  tags               TrackTag[]
  UserTrackProgress  UserTrackProgress[]

  @@index([userId])
  @@index([genreId])
  @@index([subGenreId])
  @@index([isPublic, isDeleted, isHidden])
}

model TrackArtist {
  id      String     @id @default(uuid())
  trackId String
  name    String
  role    ArtistRole
  track   Track      @relation(fields: [trackId], references: [id])
}

model TrackRegionRestriction {
  id          String @id @default(uuid())
  trackId     String
  countryCode String @db.Char(2)
  track       Track  @relation(fields: [trackId], references: [id])

  @@index([trackId])
}

model TrackTag {
  trackId String
  tag     String
  track   Track  @relation(fields: [trackId], references: [id])

  @@id([trackId, tag])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserBlock {
  id             String   @id @default(uuid())
  blockerId      String
  blockedId      String
  removeComments Boolean  @default(false)
  reportSpam     Boolean  @default(false)
  createdAt      DateTime @default(now())
  blocked        User     @relation("Blocked", fields: [blockedId], references: [id])
  blocker        User     @relation("Blocker", fields: [blockerId], references: [id])

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

   @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model PlayHistory {
  id       String   @id @default(uuid())
  userId   String
  trackId  String
  playedAt DateTime @default(now())
  track    Track    @relation(fields: [trackId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([trackId])
  @@index([playedAt])
}

model TrackLike {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())
  track     Track    @relation(fields: [trackId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([trackId])
}

model Repost {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())
  track     Track    @relation(fields: [trackId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([trackId])
}

model CollectionLike {
  id           String     @id @default(uuid())
  userId       String
  collectionId String
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([collectionId])
}

model Comment {
  id              String    @id @default(uuid())
  userId          String
  trackId         String
  parentCommentId String?
  content         String    @db.VarChar(500)
  timestamp       Int
  isEdited        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  isHidden        Boolean   @default(false)
  hiddenAt        DateTime?
  hiddenBy        String?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  deletedBy       String?
  deletedByUser   User?     @relation("CommentDeletedBy", fields: [deletedBy], references: [id])
  hiddenByUser    User?     @relation("CommentHiddenBy", fields: [hiddenBy], references: [id])
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("CommentReplies")
  track           Track     @relation(fields: [trackId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([trackId])
  @@index([parentCommentId])
}

model Collection {
  id          String            @id @default(uuid())
  userId      String
  title       String
  description String?
  coverUrl    String?
  secretToken String? @unique
  type        CollectionType
  isPublic    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  isDeleted   Boolean           @default(false)
  deletedAt   DateTime?
  user        User              @relation(fields: [userId], references: [id])
  likes       CollectionLike[]
  tracks      CollectionTrack[]

  @@index([userId])
}

model CollectionTrack {
  id           String     @id @default(uuid())
  collectionId String
  trackId      String
  position     Int
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id])
  track        Track      @relation(fields: [trackId], references: [id])

  @@index([collectionId])
  @@index([trackId])
}

model Conversation {
  id        String             @id @default(uuid())
  user1Id   String
  user2Id   String
  status    ConversationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  user1     User               @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2     User               @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages  Message[]

  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model Notification {
  id            String           @id @default(uuid())
  recipientId   String
  actorId       String?
  type          NotificationType
  referenceType ReferenceType?
  referenceId   String?
  isRead        Boolean          @default(false)
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  actor         User?            @relation("NotificationActor", fields: [actorId], references: [id])
  recipient     User             @relation("NotificationRecipient", fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([actorId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationPreference {
  userId         String
  channel        Channel
  trackLiked     Boolean @default(true)
  trackCommented Boolean @default(true)
  trackReposted  Boolean @default(true)
  userFollowed   Boolean @default(true)
  newRelease     Boolean @default(true)
  newMessage     Boolean @default(true)
  system         Boolean @default(true)
  subscription   Boolean @default(true)
  user           User    @relation(fields: [userId], references: [id])

  @@id([userId, channel])
}

model ReportReason {
  id         String              @id
  label      String              @unique
  entityType ReportedEntityType?
  reports    Report[]
}

model Report {
  id             String             @id @default(uuid())
  reporterId     String
  targetType     ReportedEntityType
  targetId       String
  reasonId       String
  description    String?
  status         ReportStatus       @default(PENDING)
  createdAt      DateTime           @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?
  adminNote      String?
  adminAction    AdminAction?
  reason         ReportReason       @relation(fields: [reasonId], references: [id])
  reporter       User               @relation("Reporter", fields: [reporterId], references: [id])
  reviewedByUser User?              @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@index([reporterId])
  @@index([targetId])
  @@index([status])
  @@index([createdAt])
}

model SubscriptionPlan {
  id                         String         @id @default(cuid())
  name                       String         @unique
  description                String?
  displayOrder               Int            @default(0)
  isActive                   Boolean        @default(true)
  monthlyPrice               Float          @default(0)
  maxTrackDurationMin        Int            @default(180)
  maxTrackSizeGB             Float?
  monthlyListenersCap        Int?
  allowedDownloads           Int            @default(0)
  enableMonetization         Boolean        @default(false)
  enablePlaylistMonetization Boolean        @default(false)
  minRevenueShare            Float?
  allowReplace               Boolean        @default(false)
  allowAdvancedTabAccess     Boolean        @default(false)
  allowScheduledRelease      Boolean        @default(false)
  allowDirectDownload        Boolean        @default(false)
  allowOfflineListening      Boolean        @default(false)
  adFree                     Boolean        @default(false)
  analytics                  Boolean        @default(false)
  advancedAnalytics          Boolean        @default(false)
  allowCollaborativeTrack    Boolean        @default(false)
  releaseScheduling          Boolean        @default(false)
  premiumStatistics          Boolean        @default(false)
  prioritySupport            Boolean        @default(false)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  monthlyUploadMinutes       Int            @default(180)
  subscriptions              Subscription[]
}

model Subscription {
  id              String            @id @default(uuid())
  userId          String
  startedAt       DateTime          @default(now())
  endedAt         DateTime?
  uploadedMinutes Int               @default(0)
  autoRenew       Boolean           @default(true)
  billingCycle    String            @default("monthly")
  createdAt       DateTime          @default(now())
  planId          String?
  renewalDate     DateTime?
  status          String            @default("active")
  updatedAt       DateTime          @default(now()) @updatedAt
  payments        Payment[]
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  subscriptionId String
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus
  paidAt         DateTime      @default(now())
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
}

model UserTrackProgress {
  userId          String
  trackId         String
  progressSeconds Int      @default(0)
  updatedAt       DateTime
  Track           Track    @relation(fields: [trackId], references: [id])
  User            User     @relation(fields: [userId], references: [id])

  @@id([userId, trackId])
}

enum LoginMethod {
  LOCAL
  GOOGLE
  FACEBOOK
  APPLE
  GITHUB
}

enum UserType {
  LISTENER
  ARTIST
  ADMIN
}

enum Visibility {
  PUBLIC
  PRIVATE
  FOLLOWERS_ONLY
}

enum OAuthProvider {
  GOOGLE
  FACEBOOK
  APPLE
  GITHUB
  TWITTER
}

enum SocialPlatform {
  INSTAGRAM
  YOUTUBE
  SPOTIFY
  TIKTOK
  SOUNDCLOUD
  TWITTER
}

enum TranscodingStatus {
  processing
  finished
  failed
}

enum FileFormat {
  mp3
  wav
  flac
  aiff
  ogg
  aac
}

enum ArtistRole {
  featured
  producer
  remixer
}

enum NotificationType {
  track_liked
  track_commented
  track_reposted
  user_followed
  new_release
  new_message
  system
  subscription
}

enum ReferenceType {
  track
  user
  conversation
  comment
}

enum Channel {
  push
  email
}

enum CollectionType {
  PLAYLIST
  ALBUM
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum ReportedEntityType {
  TRACK
  COMMENT
  USER
  COLLECTION
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum AdminAction {
  NONE
  HIDE
  REMOVE
  SUSPEND_USER
  BAN_USER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}
